rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasRole(role) {
      return isSignedIn() &&
        userDocExists() &&
        userDoc().data.role == role;
    }

    function isOrganizer() {
      return hasRole('organizer');
    }

    function isViewer() {
      return hasRole('viewer');
    }

    // Users can read their own profile. Creation allowed at signup.
    match /users/{userId} {
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow read, update, delete: if isSignedIn() && request.auth.uid == userId;
    }

    // Any authenticated user (organizer/viewer) can read tournaments.
    // Only organizers can create/update/delete tournaments.
    match /tournaments/{tournamentId} {
      allow read: if isSignedIn();
      allow create: if isOrganizer() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOrganizer() && resource.data.userId == request.auth.uid;

      // Match data is readable by all signed-in users; mutable by organizers only.
      match /matches/{matchId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isOrganizer();
      }

      // Teams data is readable by all signed-in users; mutable by organizers only.
      match /teams/{teamId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isOrganizer();

        // Players data is readable by all signed-in users; mutable by organizers only.
        match /players/{playerId} {
          allow read: if isSignedIn();
          allow create, update, delete: if isOrganizer();
        }
      }
    }
  }
}
